<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<StackPane fx:id="rootPane" xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.stockmonitor.ui.DashboardController"
           stylesheets="@../css/style.css">

    <BorderPane styleClass="main-background">

        <top>
            <HBox styleClass="header-bar">
                <Label text="Stock Monitor Dashboard" styleClass="header-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox alignment="CENTER" spacing="8">
                    <Circle fx:id="statusIndicator" radius="6" fill="#00e676"/>
                    <Label fx:id="lblNetworkStatus" text="Live" styleClass="status-label"/>
                </HBox>
                <Region prefWidth="20"/>
                <Button text="Refresh" onAction="#handleRefresh" styleClass="btn-secondary"/>
            </HBox>
        </top>

        <center>
            <VBox styleClass="tracked-section" spacing="15">
                <HBox spacing="15" alignment="CENTER_LEFT">
                    <TextField fx:id="txtSearch" promptText="Search stocks..." styleClass="input-field" prefWidth="200"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="txtAddSymbol" promptText="Symbol (e.g. AAPL)" styleClass="input-field" prefWidth="150"/>
                    <Button text="Add Stock" onAction="#handleAddStock" styleClass="btn-primary"/>
                </HBox>

                <TableView fx:id="stockTable" VBox.vgrow="ALWAYS" styleClass="modern-table">
                    <columns>
                        <TableColumn fx:id="colSymbol" text="Symbol" prefWidth="120"/>
                        <TableColumn fx:id="colPrice" text="Price" prefWidth="140"/>
                        <TableColumn fx:id="colChange" text="Change (%)" prefWidth="140"/>
                        <TableColumn fx:id="colTime" text="Last Update" prefWidth="150"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>
        </center>

        <right>
            <VBox styleClass="alerts-sidebar" spacing="20" prefWidth="350">
                <!-- Set Alert Card -->
                <VBox styleClass="card" spacing="10">
                    <Label text="Set New Alert" styleClass="card-title"/>
                    <HBox spacing="10">
                        <ComboBox fx:id="comboAlertSymbol" promptText="Symbol" styleClass="input-field" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        <ComboBox fx:id="comboCondition" promptText="Cond" styleClass="input-field" prefWidth="90"/>
                    </HBox>
                    <TextField fx:id="txtTargetPrice" promptText="Target Price (e.g. 150.0)" styleClass="input-field"/>
                    <Button text="Create Alert" onAction="#handleSetAlert" styleClass="btn-primary" maxWidth="Infinity"/>
                </VBox>

                <!-- Active Alerts Card -->
                <VBox styleClass="card" spacing="10" VBox.vgrow="ALWAYS">
                    <Label text="Active Alerts" styleClass="card-title"/>
                    <ListView fx:id="listActiveAlerts" styleClass="modern-list" VBox.vgrow="ALWAYS"/>
                </VBox>

                <!-- Triggered Alerts Card -->
                <VBox styleClass="card" spacing="10" VBox.vgrow="ALWAYS">
                    <Label text="Triggered Alerts" styleClass="card-title-red"/>
                    <ListView fx:id="listTriggeredAlerts" styleClass="modern-list" VBox.vgrow="ALWAYS"/>
                </VBox>
            </VBox>
        </right>

    </BorderPane>

</StackPane>
